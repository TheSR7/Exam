#include <iostream>
using namespace std;

void insertionSort(int arr[], int n) {
    int comparisons = 0; 

    for (int i = 1; i < n; i++) {
        int key = arr[i];
        int j = i - 1;

        
        while (j >= 0) {
            comparisons++; 
            if (arr[j] > key) {
                arr[j + 1] = arr[j];
                j--;
            } else {
                break; 
            }
        }
        arr[j + 1] = key;
    }

    
    cout << "Sorted array: ";
    for (int i = 0; i < n; i++)
        cout << arr[i] << " ";
    cout << endl;
    cout << "Total comparisons: " << comparisons << endl;
}

int main() {
    int n;
    cout << "Enter number of elements: ";
    cin >> n;

    int arr[n];
    cout << "Enter elements: ";
    for (int i = 0; i < n; i++)
        cin >> arr[i];

    insertionSort(arr, n);

    return 0;
}

