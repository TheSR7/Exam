#include <iostream>
using namespace std;

int main() {
    int n;
    cout << "Enter number of vertices: ";
    cin >> n;

    int cost[20][20];
    cout << "Enter adjacency matrix (use 0 if no edge):\n";
    for (int i = 0; i < n; i++)
        for (int j = 0; j < n; j++) {
            cin >> cost[i][j];
            if (cost[i][j] == 0 && i != j)
                cost[i][j] = 9999; // treat no edge as infinity
        }

    int s;
    cout << "Enter source vertex: ";
    cin >> s;

    int dist[20], visited[20] = {0};
    for (int i = 0; i < n; i++)
        dist[i] = cost[s][i];

    visited[s] = 1;

    for (int count = 1; count < n; count++) {
        int u = -1, min = 9999;
        for (int i = 0; i < n; i++) {
            if (!visited[i] && dist[i] < min) {
                min = dist[i];
                u = i;
            }
        }

        visited[u] = 1;

        for (int v = 0; v < n; v++) {
            if (!visited[v] && dist[u] + cost[u][v] < dist[v]) {
                dist[v] = dist[u] + cost[u][v];
            }
        }
    }

    cout << "Shortest distances from source " << s << ":\n";
    for (int i = 0; i < n; i++) {
        cout << "To " << i << " : " << dist[i] << endl;
    }

    return 0;
}


