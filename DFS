#include <iostream>
using namespace std;

int adj[20][20];   // adjacency matrix
bool visited[20];  // visited array

// DFS function
void DFS(int node, int n) {
    visited[node] = true;
    cout << node << " ";

    for (int i = 0; i < n; i++) {
        if (adj[node][i] == 1 && !visited[i]) {
            DFS(i, n);
        }
    }
}

int main() {
    int n, e;
    cout << "Enter number of vertices: ";
    cin >> n;
    cout << "Enter number of edges: ";
    cin >> e;

    // initialize adjacency matrix
    for (int i = 0; i < n; i++)
        for (int j = 0; j < n; j++)
            adj[i][j] = 0;

    cout << "Enter edges (u v):\n";
    for (int i = 0; i < e; i++) {
        int u, v;
        cin >> u >> v;
        adj[u][v] = 1;
        adj[v][u] = 1; // for undirected graph
    }

    int start;
    cout << "Enter starting vertex: ";
    cin >> start;

    // initialize visited array
    for (int i = 0; i < n; i++)
        visited[i] = false;

    cout << "DFS traversal: ";
    DFS(start, n);
    cout << endl;

    return 0;
}


