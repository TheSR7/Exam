#include <iostream>
using namespace std;

int main() {
    int n;
    cout << "Enter number of vertices: ";
    cin >> n;

    int cost[20][20];
    cout << "Enter adjacency matrix (use 0 if no edge):\n";
    for (int i = 0; i < n; i++)
        for (int j = 0; j < n; j++)
            cin >> cost[i][j];

    int visited[20] = {0};
    visited[0] = 1; // start from vertex 0

    int edges = 0, minCost = 0;

    cout << "Edges in MST:\n";
    while (edges < n - 1) {
        int u = -1, v = -1, min = 9999;

        // find minimum edge
        for (int i = 0; i < n; i++) {
            if (visited[i]) {
                for (int j = 0; j < n; j++) {
                    if (!visited[j] && cost[i][j] != 0) {
                        if (cost[i][j] < min) {
                            min = cost[i][j];
                            u = i;
                            v = j;
                        }
                    }
                }
            }
        }

        cout << u << " - " << v << " : " << min << endl;
        visited[v] = 1;
        minCost += min;
        edges++;
    }

    cout << "Total cost of MST = " << minCost << endl;
    return 0;
}


